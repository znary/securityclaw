{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecurityDecisionEvent",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "trace_id",
    "hook",
    "decision",
    "reason_codes",
    "latency_ms",
    "ts"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "event_type": { "const": "SecurityDecisionEvent" },
    "trace_id": { "type": "string" },
    "hook": {
      "type": "string",
      "enum": [
        "before_prompt_build",
        "before_tool_call",
        "after_tool_call",
        "tool_result_persist",
        "message_sending"
      ]
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "warn", "challenge", "block"]
    },
    "reason_codes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "latency_ms": { "type": "number", "minimum": 0 },
    "ts": { "type": "string", "format": "date-time" }
  }
}
