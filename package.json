{
  "name": "safeclaw",
  "version": "0.1.0",
  "description": "SafeClaw security plugin for OpenClaw-compatible hooks.",
  "type": "module",
  "private": true,
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "node --test --experimental-strip-types",
    "test": "npm run typecheck && npm run test:unit",
    "check": "npm test",
    "admin": "node --experimental-strip-types ./admin/server.ts",
    "admin:build": "node ./scripts/build-admin.mjs"
  },
  "dependencies": {
    "esbuild": "^0.27.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "openclaw": "^2026.3.13",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "openclaw": "^2026.3.13"
  }
}
