{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": true
  },
  "include": [
    "index.ts",
    "admin/src/**/*.jsx",
    "src/**/*.ts",
    "tests/**/*.ts"
  ]
}
